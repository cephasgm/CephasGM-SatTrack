# ============================================
# CephasGM SatTrack - Environment Variables
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Default Terminal Location (used if GPS not available)
DEFAULT_LATITUDE=-1.2921
DEFAULT_LONGITUDE=36.8219
DEFAULT_ALTITUDE=1680

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CLIENTS=100

# CORS Configuration
CORS_ORIGIN=*